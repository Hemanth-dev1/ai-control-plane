# =============================================================================
# Enterprise AI Control Plane — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running docker compose up
# =============================================================================

# --- Control Plane ---
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8000
CONTROL_PLANE_LOG_LEVEL=INFO
CONTROL_PLANE_DATABASE_URL=postgresql+asyncpg://controlplane:controlplane@postgres:5432/controlplane
CONTROL_PLANE_REDIS_URL=redis://redis:6379/0
CONTROL_PLANE_JWT_SECRET_KEY=change-me-to-a-strong-random-secret-in-production
CONTROL_PLANE_JWT_ALGORITHM=HS256
CONTROL_PLANE_JWT_EXPIRATION_SECONDS=3600
CONTROL_PLANE_OPA_URL=http://opa:8181
CONTROL_PLANE_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
CONTROL_PLANE_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- Agent Runtime ---
AGENT_RUNTIME_HOST=0.0.0.0
AGENT_RUNTIME_PORT=8001
AGENT_RUNTIME_LOG_LEVEL=INFO
AGENT_RUNTIME_CONTROL_PLANE_URL=http://control-plane:8000
AGENT_RUNTIME_TOOL_GATEWAY_URL=http://tool-gateway:8002
AGENT_RUNTIME_ANTHROPIC_API_KEY=<your-anthropic-api-key>
AGENT_RUNTIME_LLM_MODEL=claude-sonnet-4-20250514
AGENT_RUNTIME_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
AGENT_RUNTIME_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
AGENT_RUNTIME_CLIENT_ID=agent-runtime
AGENT_RUNTIME_CLIENT_SECRET=change-me-in-production

# --- Tool Gateway ---
TOOL_GATEWAY_HOST=0.0.0.0
TOOL_GATEWAY_PORT=8002
TOOL_GATEWAY_LOG_LEVEL=INFO
TOOL_GATEWAY_CRM_SERVICE_URL=http://crm-service:8003
TOOL_GATEWAY_TICKETING_SERVICE_URL=http://ticketing-service:8004
TOOL_GATEWAY_NOTIFICATION_SERVICE_URL=http://notification-service:8005
TOOL_GATEWAY_KAFKA_BOOTSTRAP_SERVERS=kafka:9092
TOOL_GATEWAY_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
TOOL_GATEWAY_CONTROL_PLANE_URL=http://control-plane:8000

# --- Postgres ---
POSTGRES_USER=controlplane
POSTGRES_PASSWORD=controlplane
POSTGRES_DB=controlplane
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=ai-control-plane

# --- OPA ---
OPA_URL=http://opa:8181

{
  "title": "Tool Call Volume & Policy Deny Rate",
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Tool Call Volume by Tool",
      "type": "barchart",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(tool_gateway_tool_calls_total[5m])) by (tool_name)",
          "legendFormat": "{{tool_name}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Tool Call Success vs Failure Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(tool_gateway_tool_calls_total{success=\"true\"}[5m])",
          "legendFormat": "success"
        },
        {
          "expr": "rate(tool_gateway_tool_calls_total{success=\"false\"}[5m])",
          "legendFormat": "failure"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Policy Deny Rate by Agent",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(control_plane_policy_decisions_total{decision=\"denied\"}[5m])",
          "legendFormat": "denied"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Token Usage Over Time",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(agent_runtime_tokens_total[5m])",
          "legendFormat": "tokens/sec"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}

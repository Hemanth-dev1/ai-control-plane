{
  "title": "Service Latency & Error Rate",
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "title": "Request Latency (P95) per Service",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(control_plane_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "control-plane: {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(agent_runtime_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "agent-runtime: {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(tool_gateway_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "tool-gateway: {{endpoint}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(control_plane_request_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(control_plane_request_duration_seconds_count[5m]))",
          "legendFormat": "control-plane"
        },
        {
          "expr": "sum(rate(agent_runtime_request_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(agent_runtime_request_duration_seconds_count[5m]))",
          "legendFormat": "agent-runtime"
        },
        {
          "expr": "sum(rate(tool_gateway_request_duration_seconds_count{status_code=~\"5..\"}[5m])) / sum(rate(tool_gateway_request_duration_seconds_count[5m]))",
          "legendFormat": "tool-gateway"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Policy Decisions (Allow vs Deny)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(control_plane_policy_decisions_total{decision=\"allowed\"}[5m])",
          "legendFormat": "allowed"
        },
        {
          "expr": "rate(control_plane_policy_decisions_total{decision=\"denied\"}[5m])",
          "legendFormat": "denied"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "title": "Agent Operations",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(control_plane_agent_operations_total[5m])",
          "legendFormat": "{{operation}}"
        }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    }
  ]
}
